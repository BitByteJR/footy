# Copy to .env and adjust. The real .env is gitignored.

# --- PostgreSQL (consumed by compose.yaml) ---
POSTGRES_DB=footy
POSTGRES_USER=footy
POSTGRES_PASSWORD=footy_dev_password
# Change if port 5432 is already used on your host (e.g. local Postgres install).
POSTGRES_PORT=5432

# --- App DSN (will be read by FastAPI/Alembic in Phase 2) ---
DATABASE_URL=postgresql://footy:footy_dev_password@localhost:5432/footy
