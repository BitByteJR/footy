# Copy to .env and adjust. The real .env is gitignored.

# --- PostgreSQL (consumed by compose.yaml) ---
POSTGRES_DB=footy
POSTGRES_USER=footy
POSTGRES_PASSWORD=footy_dev_password
# 15432 is a common convention for dockerised Postgres; well away from host installs on 5432/5433.
POSTGRES_PORT=15432

# --- App DSN (read by FastAPI / Alembic when run on the host) ---
# `+psycopg` selects the psycopg3 driver, which is what we install.
# Used by `just dev` / `just migrate`. Inside compose the `api` service uses its own DSN.
DATABASE_URL=postgresql+psycopg://footy:footy_dev_password@localhost:15432/footy

# --- API (compose: api service host port) ---
API_PORT=8000

# Optional: free token from football-data.org (without it endpoints are rate-limited)
# FOOTBALL_DATA_TOKEN=
